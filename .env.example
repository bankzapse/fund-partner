# ---- Supabase (ต้องตั้งบน Vercel ก่อน deploy) ----
# เอามาจาก Supabase Dashboard > Project Settings > Database > Connection string > URI
# ใช้แบบ "Connection pooling" (พอร์ต 6543) สำหรับ Serverless
DATABASE_URL=postgresql://postgres.xxxxxxxx:YOUR-PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ---- ที่เก็บไฟล์แนบ (Supabase Storage) ----
# Dashboard > Project Settings > API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_STORAGE_BUCKET=fund-partner

# ---- อื่น ๆ ----
NODE_ENV=production
